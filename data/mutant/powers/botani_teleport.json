{
    "type": "origins:multiple",
    "name": "Underground Traverse",
    "description": "You can delve down and come out on another side in a short 20 block distance quickly as if teleporting provided you are standing on a block. Very short cooldown.",
    "tag": {
        "type": "origins:action_on_callback",
        "entity_action_gained": {
            "type": "origins:execute_command",
            "command": "tag @s add botani"
        },
        "entity_action_lost": {
            "type": "origins:execute_command",
            "command": "tag @s remove botani"
        }
    },
    "tp": {
        "type": "origins:active_self",
        "cooldown": 40,
        "key": "key.origins.tertiary_active",
        "condition": {
            "type": "origins:and",
            "conditions": [
                {
                    "type": "origins:raycast",
                    "distance": 20,
                    "block": true,
                    "entity": true,
                    "shape_type": "visual",
                    "fluid_handling": "any"
                },
                {
                    "type": "origins:on_block"
                },
                {
                    "type": "origins:power",
                    "power": "mutant:botani_rooted_power",
                    "source": "mutant:botani",
                    "inverted": true
                }
            ]
        },
        "entity_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:play_sound",
                    "sound": "minecraft:entity.enderman.teleport"
                },
                {
                    "type": "origins:change_resource",
                    "resource": "mutant:botani_nutrients",
                    "change": -1
                },
                {
                    "type": "origins:spawn_particles",
                    "particle": {
                        "type": "minecraft:block",
                        "params": "minecraft:dirt"
                    },
                    "count": 500,
                    "spread": {
                        "x": 1,
                        "y": 1,
                        "z": 1
                    }
                },
                {
                    "type": "origins:raycast",
                    "distance": 20,
                    "block": true,
                    "entity": true,
                    "shape_type": "visual",
                    "fluid_handling": "any",
                    "command_at_hit": "function mutant:botani_tp"
                }
            ]
        }
    }
}