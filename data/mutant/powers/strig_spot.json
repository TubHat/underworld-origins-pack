{
    "type": "origins:multiple",
    "name": "Spot Prey",
    "description": "When looking at an entity for 3 seconds, mark them as prey, giving them weakness and glowing for 10 seconds.",
    "spot": {
        "type": "origins:action_over_time",
        "interval": 20,
        "entity_action": {
            "type": "origins:if_else",
            "if_action": {
                "type": "origins:change_resource",
                "resource": "mutant:strig_spot_hunt",
                "change": 1
            },
            "else_action": {
                "type": "origins:change_resource",
                "resource": "mutant:strig_spot_hunt",
                "change": -1
            },
            "condition": {
                "type": "origins:raycast",
                "block": false,
                "entity": true,
                "distance": 80
            }
        }
    },
    "hunt": {
        "type": "origins:resource",
        "max": 3,
        "min": 0,
        "start_value": 0,
        "max_action": {
            "type": "origins:raycast",
            "block": false,
            "entity": true,
            "bientity_action": {
                "type": "origins:and",
                "actions": [
                    {
                        "type": "origins:actor_action",
                        "action": {
                            "type": "origins:and",
                            "actions": [
                                {
                                    "type": "origins:execute_command",
                                    "command": "tellraw @s prey"
                                },
                                {
                                    "type": "origins:change_resource",
                                    "resource": "mutant:strig_spot_hunt",
                                    "change": -3
                                }
                            ]
                        }
                    },
                    {
                        "type": "origins:target_action",
                        "action": {
                            "type": "origins:execute_command",
                            "command": "function mutant:spot_prey"
                        }
                    }
                ]
            },
            "distance": 80
        }
    }
}
