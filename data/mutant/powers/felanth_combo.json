{
    "type": "origins:multiple",
    "name": "Blood Lust",
    "description": "You have a combo meter, the more you attack the more it fills up, pressing ability key at a certain point will give you stronger buffs the more full it is.",
    "combo": {
        "hud_render": {
            "should_render": true,
            "sprite_location": "origins:textures/gui/community/spiderkolo/resource_bar_02.png",
            "bar_index": 1
        },
        "type": "origins:resource",
        "min": 0,
        "max": 30,
        "start_value": 0
    },
    "increase_combo": {
        "type": "origins:self_action_on_hit",
        "entity_action": {
            "type": "origins:change_resource",
            "resource": "*:*_combo",
            "change": 1
        }
    },
    "decrease_combo": {
        "type": "origins:action_over_time",
        "interval": 40,
        "entity_action": {
            "type": "origins:change_resource",
            "resource": "*:*_combo",
            "change": -1
        },
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_drag",
            "comparison": "==",
            "compare_to": 1
        }
    },
    "drag": {
        "hud_render": {
            "should_render": false
        },
        "type": "origins:resource",
        "min": 0,
        "max": 1,
        "start_value": 1
    },
    "decrease_drag": {
        "type": "origins:self_action_on_hit",
        "entity_action": {
            "type": "origins:set_resource",
            "resource": "*:*_drag",
            "value": 0
        }
    },
    "increase_drag": {
        "type": "origins:action_over_time",
        "interval": 120,
        "entity_action": {
            "type": "origins:set_resource",
            "value": 1,
            "resource": "*:*_drag"
        },
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_drag",
            "compare_to": 0,
            "comparison": "=="
        }
    },
    "low": {
