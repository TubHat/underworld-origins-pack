{
    "name": "In a blink",
    "description": "You can use your feline agility to suddenly appear behind the closest entity in proximity. press primary while sneaking.",
    "type": "origins:multiple",
    "tag": {
        "type": "origins:action_on_callback",
        "entity_action_gained": {
            "type": "origins:execute_command",
            "command": "tag @s add felanth"
        },
        "entity_action_lost": {
            "type": "origins:execute_command",
            "command": "tag @s remove felanth"
        }
    },
    "invis": {
        "type": "origins:resource",
        "min": 0,
        "max": 1,
        "start_value": 0,
        "hud_render": {
            "should_render": false,
            "sprite_location": "origins:textures/gui/resource_bar.png"
        }
    },
    "ghost": {
        "type": "origins:invisibility",
        "render_armor": false,
        "condition": {
            "type": "origins:resource",
            "inverted": false,
            "comparison": "==",
            "resource": "*:*_invis",
            "compare_to": 1
        }
    },
    "activate": {
        "type": "origins:active_self",
        "cooldown": 200,
        "hud_render": {
            "should_render": true,
            "sprite_location": "origins:textures/gui/resource_bar.png",
            "bar_index": 6
        },
        "entity_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:change_resource",
                    "resource": "*:*_invis",
                    "change": 1
                },
                {
                    "type": "origins:execute_command",
                    "permission_level": 4,
                    "command": "particle minecraft:poof ~ ~.5 ~ .3 .5 .3 0 50 normal"
                },
                {
                    "type": "origins:execute_command",
                    "permission_level": 4,
                    "command": "playsound minecraft:block.wool.fall player @a[distance=..10] ~ ~ ~ .5 0"
                },
                {
                    "type": "origins:raycast",
                    "entity": true,
                    "distance": 15,
                    "block": false,
                    "fluid_handling": "any",
                    "bientity_condition": {
                        "type": "origins:target_condition",
                        "condition": {
                            "type": "origins:living"
                        }
                    },
                    "command_at_hit": "execute as @e[limit=1,sort=nearest] at @p[tag=felanth] run tp @s ^ ^ ^-1.2 facing entity @s feet"
                },
                {
                    "type": "origins:delay",
                    "ticks": 5,
                    "action": {
                        "type": "origins:change_resource",
                        "resource": "*:*_invis",
                        "change": -1
                    }
                }
            ]
        },
        "condition": {
            "type": "origins:sneaking",
            "inverted": false
        },
        "key": {
            "key": "key.origins.primary_active"
        }
    }
}