{
    "hidden": false,
    "name": "Rock Crawl",
    "description": "You can craw through stone like blocks at the cost of increased exhaustion.",
    "type": "origins:active_self",
    "cooldown": 20,
    "key": "primary",
    "entity_action": {
        "type": "origins:if_else_list",
        "actions": [
            {
                "condition": {
                    "type": "origins:and",
                    "conditions": [
                        {
                            "type": "origins:power",
                            "power": "packname:rock_crawl"
                        },
                        {
                            "type": "origins:living"
                        }
                    ]
                },
                "action": {
                    "type": "origins:and",
                    "actions": [
                        {
                            "type": "origins:play_sound",
                            "sound": "minecraft:block.stone.break"
                        },
                        {
                            "type": "origins:execute_command",
                            "command": "/tellraw @a {\"text\":\"I will NOT crawl\",\"color\":\"dark_green\"}"
                        },
                        {
                            "type": "origins:revoke_power",
                            "power": "packname:rock_crawl",
                            "source": "packname:your_origin"
                        }
                    ]
                }
            },
            {
                "condition": {
                    "type": "origins:and",
                    "conditions": [
                        {
                            "type": "origins:power",
                            "power": "packname:rock_crawl",
                            "inverted": true
                        },
                        {
                            "type": "origins:living"
                        }
                    ]
                },
                "action": {
                    "type": "origins:and",
                    "actions": [
                        {
                            "type": "origins:play_sound",
                            "sound": "minecraft:block.stone.place"
                        },
                        {
                            "type": "origins:execute_command",
                            "command": "/tellraw @a {\"text\":\"I will crawl\",\"color\":\"dark_green\"}"
                        },
                        {
                            "type": "origins:grant_power",
                            "power": "packname:rock_crawl",
                            "source": "packname:your_origin"
                        }
                    ]
                }
            }
        ]
    }
}