{
    "type": "origins:multiple",
    "name": "Root Self",
    "description": "Press ability key to toggle \"Rooted\" state, in this, you will slowly gain satiation and regenerate health, increase nutrients meter slowly over time, gain increased damage resistance, but take 2x fire damage and become unable to move. Attempting to move will result in uprooting, damaging you, and resetting nutrients meter.",
    "toggle": {
        "type": "origins:active_self",
        "key": "key.origins.primary_active",
        "entity_action": {
            "type": "origins:if_else",
            "if_action": {
                "type": "origins:and",
                "actions": [
                    {
                        "type": "origins:grant_power",
                        "power": "mutant:botani_rooted_power",
                        "source": "mutant:botani"
                    },
                    {
                        "type": "origins:execute_command",
                        "command": "/tellraw @s {\"text\":\"I am rooted.\",\"color\":\"dark_green\"}"
                    },
                    {
                        "type": "origins:apply_effect",
                        "effects": [
                            {
                                "effect": "slowness",
                                "amplifier": 14,
                                "duration": 80
                            },
                            {
                                "effect": "regeneration",
                                "duration": 20
                            },
                            {
                                "effect": "resistance",
                                "duration": 80,
                                "amplifier": 1
                            },
                            {
                                "effect": "jump_boost",
                                "amplifier": 200,
                                "duration": 80
                            }
                        ]
                    },
                    {
                        "type": "origins:change_resource",
                        "resource": "mutant:botani_rooted_hud",
                        "change": 1
                    },
                    {
                        "type": "origins:spawn_particles",
                        "particle": "minecraft:spore_blossom_air",
                        "count": 500,
                        "spread": {
                            "x": 1,
                            "y": 1,
                            "z": 1
                        }
                    },
                    {
                        "type": "origins:play_sound",
                        "sound": "minecraft:block.wet_grass.place",
                        "volume": 2,
                        "pitch": 0.7
                    }
                ]
            },
            "else_action": {
                "type": "origins:and",
                "actions": [
                    {
                        "type": "origins:change_resource",
                        "resource": "mutant:botani_rooted_hud",
                        "change": -1
                    },
                    {
                        "type": "origins:execute_command",
                        "command": "/tellraw @s {\"text\":\"I am unrooted\",\"color\":\"dark_green\"}"
                    },
                    {
                        "type": "origins:revoke_power",
                        "power": "mutant:botani_rooted_power",
                        "source": "mutant:botani"
                    },
                    {
                        "type": "origins:spawn_particles",
                        "particle": {
                            "type": "minecraft:dust",
                            "params": "1 0.8 0 1"
                        },
                        "count": 500,
                        "spread": {
                            "x": 1,
                            "y": 1,
                            "z": 1
                        }
                    },
                    {
                        "type": "origins:play_sound",
                        "sound": "minecraft:block.grass.place",
                        "volume": 2,
                        "pitch": 0.7
                    }
                ]
            },
            "condition": {
                "type": "origins:power",
                "power": "mutant:botani_rooted_power",
                "inverted": true
            }
        }
    },
    "fire": {
        "type": "origins:modify_damage_taken",
        "modifier": {
            "operation": "multiply_base",
            "value": 1
        },
        "damage_condition": {
            "type": "origins:fire"
        }
    },
    "power": {
        "type": "origins:action_over_time",
        "interval": 60,
        "condition": {
            "type": "origins:power_active",
            "power": "mutant:botani_rooted_toggle"
        },
        "entity_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:apply_effect",
                    "effects": [
                        {
                            "effect": "slowness",
                            "amplifier": 14,
                            "duration": 80
                        },
                        {
                            "effect": "regeneration",
                            "duration": 20
                        },
                        {
                            "effect": "resistance",
                            "duration": 80,
                            "amplifier": 1
                        },
                        {
                            "effect": "jump_boost",
                            "amplifier": 200,
                            "duration": 80
                        }
                    ]
                },
                {
                    "type": "origins:feed",
                    "food": 1,
                    "saturation": 1
                },
                {
                    "type": "origins:play_sound",
                    "sound": "farmersdelight:block.skillet.add_food",
                    "volume": 0.5,
                    "pitch": 1.5
                },
                {
                    "type": "origins:change_resource",
                    "resource": "mutant:botani_nutrients",
                    "change": 2
                },
                {
                    "type": "origins:if_else",
                    "if_action": {
                        "type": "origins:and",
                        "actions": [
                            {
                                "type": "origins:damage",
                                "amount": 4,
                                "source": {
                                    "name": "generic",
                                    "bypasses_armor": true,
                                    "unblockable": true
                                }
                            },
                            {
                                "type": "origins:change_resource",
                                "resource": "mutant:botani_nutrients",
                                "operation": "set",
                                "change": 0
                            },
                            {
                                "type": "origins:change_resource",
                                "resource": "mutant:botani_rooted_hud",
                                "change": -1
                            },
                            {
                                "type": "origins:execute_command",
                                "command": "/tellraw @s {\"text\":\"I am unrooted.\",\"color\":\"dark_green\"}"
                            },
                            {
                                "type": "origins:revoke_power",
                                "power": "mutant:botani_rooted_power",
                                "source": "mutant:botani"
                            }
                        ]
                    },
                    "condition": {
                        "type": "origins:or",
                        "conditions": [
                            {
                                "type": "origins:on_block",
                                "inverted": true
                            },
                            {
                                "type": "origins:moving"
                            }
                        ]
                    }
                }
            ]
        }
    },
    "hud": {
        "type": "origins:resource",
        "max": 1,
        "min": 0,
        "start_value": 1,
        "hud_render": {
            "sprite_location": "origins:textures/gui/community/huang/resource_bar_01.png",
            "bar_index": 20
        }
    },
    "remove": {
        "type": "origins:action_on_callback",
        "entity_action_lost": {
            "type": "origins:remove_power",
            "power": "botani_rooted",
            "source": "mutant:botani"
        }
    }
}