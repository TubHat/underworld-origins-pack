{
    "type": "origins:action_on_callback",
    "name": "Step Height",
    "description": "Automatically step up 1 block high, like horses.",
    "entity_action_gained": {
        "type": "origins:execute_command",
        "command": "scale set pehkui:step_height 1.5 @s"
    },
    "entity_action_lost": {
        "type": "origins:execute_command",
        "command": "scale reset pehkui:step_height @s"
    }
}