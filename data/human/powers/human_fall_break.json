{
    "type": "origins:multiple",
    "name": "Fall Break",
    "description": "Time your sneak mid air perfectly to negate fall damage (Not recommended if you are laggy).",
    "resource": {
        "type": "origins:resource",
        "min": 0,
        "max": 1,
        "start_value": 1,
        "hud_render": {
            "should_render": false
        }
    },
    "resource_regen": {
        "type": "origins:action_over_time",
        "interval": 60,
        "entity_action": {
            "type": "origins:change_resource",
            "resource": "*:*_resource",
            "change": 1
        },
        "condition": {
            "type": "origins:and",
            "conditions": [
                {
                    "type": "origins:resource",
                    "resource": "*:*_resource",
                    "comparison": "==",
                    "compare_to": 0
                },
                {
                    "type": "origins:on_block"
                }
            ]
        }
    },
    "break": {
        "type": "origins:active_self",
        "entity_action": {
            "type": "origins:apply_effect",
            "effect": {
                "effect": "minecraft:slow_falling",
                "duration": 5,
                "show_particles": false,
                "show_icon": false
            }
        },
        "condition": {
            "type": "origins:and",
            "conditions": [
                {             
                    "type": "origins:resource",
                    "resource": "*:*_resource",
                    "comparison": "==",
                    "compare_to": 1
                },
                {
                    "type": "origins:on_block",
                    "inverted": true
                }
            ]
        },
        "key": "key.sneak"
    } 
}